{
	"name": "@querypanel/sdk",
	"version": "1.1.0",
	"description": "TypeScript/Node.js SDK for the QueryPanel API",
	"license": "UNLICENSED",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/querypanel/node-sdk.git"
	},
	"author": "QueryPanel",
	"homepage": "https://querypanel.io",
	"bugs": {
		"url": "https://github.com/querypanel/node-sdk/issues"
	},
	"keywords": [
		"querypanel",
		"sdk",
		"node",
		"javascript",
		"typescript",
		"text-to-dashboard",
		"natural-language-to-sql",
		"text-to-sql"
	],
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"check": "tsc --noEmit"
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"jose": "^6.1.1"
	},
	"devDependencies": {
		"tsup": "^8.5.1",
		"typescript": "^5.6.3"
	}
}
